{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": [
      "ESNext",
      "dom",
    ],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "rootDir": "src",
    "outDir": "dist",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@exsit/shared/*": ["../shared/src/*"]
    },
    "types": ["node"]
  },
  "include": [
    "src/**/*",
  ],
  "exclude": [
    "node_modules"
  ],
  "references": [
    {"path": "../shared"}
  ]
}